# =============================================================================
# DaBaShou Docker 环境变量配置
# 使用方法: 复制此文件为 .env 并根据需要修改
#   cp .env.example .env
# =============================================================================

# 服务端口配置
HTTP_PORT=80
FRONTEND_PORT=5173
BACKEND_PORT=9090
MYSQL_PORT=3306
REDIS_PORT=6379

# MySQL 配置
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=dabashou

# Redis 配置 (留空表示无密码)
REDIS_PASSWORD=

# JWT 配置 (生产环境请修改为随机字符串)
JWT_SECRET=your-256-bit-secret-key-here-change-in-production

# Spring Profile (dev 或 prod)
SPRING_PROFILES_ACTIVE=dev
