/** 搭把手 微信小程序 — 全局样式（闲鱼风格） */

/* ===== CSS 变量（设计Token） ===== */
page {
  /* 品牌色 — 闲鱼橙系 */
  --color-primary: #FF6E14;
  --color-primary-light: #FF8A4C;
  --color-primary-dark: #E55A00;

  /* 强调色 */
  --color-accent: #FFDE2E;        /* 闲鱼亮黄 */
  --color-price: #FF4444;          /* 闲鱼价格红 */

  /* 功能色 */
  --color-success: #2ba471;
  --color-warning: #e37318;
  --color-error: #d54941;
  --color-info: #909399;

  /* 文字色 */
  --text-primary: #1d2129;
  --text-regular: #4e5969;
  --text-secondary: #86909c;
  --text-placeholder: #c9cdd4;

  /* 背景色 */
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --bg-hover: #f7f8fa;

  /* 边框 */
  --border-color: #e5e6eb;
  --border-radius-sm: 8rpx;
  --border-radius-md: 16rpx;
  --border-radius-lg: 20rpx;
  --border-radius-round: 999rpx;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;

  /* 字体 */
  --font-size-xs: 20rpx;
  --font-size-sm: 24rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;

  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);

  /* 导航栏高度 */
  --navbar-height: 88rpx;
  --tabbar-height: 100rpx;

  /* 安全区域 */
  --safe-area-bottom: env(safe-area-inset-bottom);
}

/* ===== 基础重置 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', 'Helvetica Neue', Arial, sans-serif;
  font-size: var(--font-size-md);
  color: var(--text-primary);
  background-color: var(--bg-page);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ===== 工具类 ===== */

/* 文字 */
.text-primary   { color: var(--text-primary); }
.text-regular   { color: var(--text-regular); }
.text-secondary { color: var(--text-secondary); }
.text-small     { font-size: var(--font-size-sm); }
.text-center    { text-align: center; }
.text-bold      { font-weight: 600; }

/* 间距 */
.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.p-sm  { padding: var(--spacing-sm); }
.p-md  { padding: var(--spacing-md); }
.p-lg  { padding: var(--spacing-lg); }

/* 布局 */
.flex       { display: flex; }
.flex-col   { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1     { flex: 1; }

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: var(--border-radius-md);
  padding: var(--spacing-md);
  margin: var(--spacing-sm) var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

/* 安全区域底部占位 */
.safe-bottom {
  padding-bottom: var(--safe-area-bottom);
}

/* 一行省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 两行省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: var(--spacing-sm) 0;
}
