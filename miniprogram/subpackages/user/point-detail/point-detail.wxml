<view class="page">
  <!-- 积分余额卡片 -->
  <view class="balance-card">
    <view class="balance-header">当前积分</view>
    <view class="balance-amount">{{account.available || 0}}</view>
    <view class="balance-frozen" wx:if="{{account.frozen > 0}}">
      冻结积分：{{account.frozen}}
    </view>
    <view class="balance-stats">
      <view class="stat-item">
        <text class="stat-label">累计收入</text>
        <text class="stat-value income">+{{account.totalEarned || 0}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-label">累计支出</text>
        <text class="stat-value expense">-{{account.totalSpent || 0}}</text>
      </view>
    </view>
  </view>

  <!-- 筛选 Tab -->
  <t-tabs value="{{activeTab}}" bind:change="onTabChange">
    <t-tab-panel wx:for="{{filterTabs}}" wx:key="value" label="{{item.label}}" value="{{item.value}}" />
  </t-tabs>

  <!-- 加载状态 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <t-loading theme="circular" size="40rpx" text="加载中..." />
  </view>

  <!-- 空状态 -->
  <view class="empty-wrap" wx:elif="{{empty}}">
    <t-empty description="暂无交易记录" />
  </view>

  <!-- 交易列表 -->
  <view class="transaction-list" wx:else>
    <view
      class="transaction-item"
      wx:for="{{transactions}}"
      wx:key="id"
    >
      <view class="item-left">
        <view class="item-icon {{isIncomeType(item.type) ? 'icon-income' : 'icon-expense'}}">
          <text>{{item.description.slice(0, 1)}}</text>
        </view>
        <view class="item-info">
          <text class="item-desc">{{item.description}}</text>
          <text class="item-time">{{item.createTime}}</text>
        </view>
      </view>
      <view class="item-amount {{isIncomeType(item.type) ? 'amount-income' : 'amount-expense'}}">
        {{isIncomeType(item.type) ? '+' : ''}}{{item.amount}}
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loadingMore}}">
      <t-loading theme="circular" size="30rpx" text="加载更多..." />
    </view>
    <view class="no-more" wx:elif="{{!hasMore && transactions.length > 0}}">
      — 没有更多了 —
    </view>
  </view>
</view>
