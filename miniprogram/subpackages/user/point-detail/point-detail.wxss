.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ===== 余额卡片 ===== */
.balance-card {
  margin: 24rpx;
  padding: 40rpx 32rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ff8c00, #ff6b35);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.3);
}

.balance-header {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 12rpx;
}

.balance-amount {
  font-size: 72rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.balance-frozen {
  font-size: 26rpx;
  margin-top: 8rpx;
  opacity: 0.8;
}

.balance-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.25);
}

.stat-item {
  display: flex;
  flex-direction: column;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.75;
  margin-bottom: 4rpx;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 600;
}

.stat-value.income {
  color: #fff;
}

.stat-value.expense {
  color: rgba(255, 255, 255, 0.8);
}

/* ===== 加载/空状态 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-wrap {
  padding: 120rpx 0;
}

/* ===== 交易列表 ===== */
.transaction-list {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.transaction-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
  background: #fff;
  border-radius: 12rpx;
}

.item-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.item-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.icon-income {
  background: #e8f8e8;
  color: #2ba471;
}

.icon-expense {
  background: #fde8e8;
  color: #d54941;
}

.item-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.item-desc {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.item-amount {
  font-size: 32rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.amount-income {
  color: #2ba471;
}

.amount-expense {
  color: #333;
}

/* ===== 底部状态 ===== */
.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #999;
}
