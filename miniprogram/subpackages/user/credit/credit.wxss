.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ===== 信任分展示区 ===== */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 0 40rpx;
  background: linear-gradient(180deg, #e8f4ff 0%, #f5f5f5 100%);
}

.score-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.score-value {
  font-size: 96rpx;
  font-weight: 700;
  color: #0052d9;
  line-height: 1;
  margin-bottom: 20rpx;
  letter-spacing: 4rpx;
}

/* ===== 加载/空状态 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-wrap {
  padding: 120rpx 0;
}

/* ===== 评价列表 ===== */
.review-list {
  padding: 0 24rpx;
  margin-top: 16rpx;
}

.review-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 12rpx;
}

.review-header {
  display: flex;
  align-items: center;
}

.review-meta {
  flex: 1;
  margin-left: 16rpx;
}

.review-nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.review-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.review-content {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid #f0f0f0;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

/* ===== 底部状态 ===== */
.load-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
  font-size: 24rpx;
  color: #999;
}
