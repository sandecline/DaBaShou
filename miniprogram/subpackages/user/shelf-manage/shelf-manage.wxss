.shelf-manage-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.empty-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.shelf-list {
  padding: 16rpx 24rpx;
}

.shelf-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.shelf-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.shelf-card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.shelf-card__info {
  display: flex;
  gap: 16rpx;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.shelf-card__price {
  color: #e34d59;
  font-weight: 600;
}

.shelf-card__stats {
  display: flex;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.shelf-card__edit-btn {
  margin-top: 8rpx;
}

/* 发布按钮栏 */
.publish-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}

/* 滑动操作按钮样式 */
.swipe-btn-on {
  background: #0052d9;
  color: #fff;
}

.swipe-btn-off {
  background: #e34d59;
  color: #fff;
}
