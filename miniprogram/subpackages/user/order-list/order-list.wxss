.order-list-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.order-list {
  padding: 16rpx 24rpx;
}

.order-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.order-card__header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-card__no {
  font-size: 24rpx;
  color: #999;
}

.order-card__body {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.order-card__title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-card__point {
  font-size: 28rpx;
  color: #e34d59;
  font-weight: 600;
  margin-left: 16rpx;
}

.order-card__footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.order-card__user {
  display: flex;
  align-items: center;
}

.order-card__avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.order-card__name {
  font-size: 26rpx;
  color: #666;
}

.order-card__role {
  font-size: 22rpx;
  color: #999;
  margin-left: 8rpx;
}

.order-card__time {
  font-size: 24rpx;
  color: #999;
}
