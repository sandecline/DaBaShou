.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding-top: 200rpx;
}

/* ===== 统计卡片网格 ===== */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
}

.stat-card {
  width: calc(50% - 16rpx);
  margin: 8rpx;
  padding: 36rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-header {
  margin-bottom: 16rpx;
}

.card-label {
  font-size: 26rpx;
  color: #666;
}

.card-body {
  display: flex;
  align-items: baseline;
}

.card-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #333;
  line-height: 1;
}

.card-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 6rpx;
}
