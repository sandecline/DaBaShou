/* 编辑资料页 — 闲鱼风格卡片化布局 */

.page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ===== 顶部渐变区 ===== */
.hero {
  background: linear-gradient(135deg, #FF6E14 0%, #FF8A4C 100%);
  padding: 48rpx 0 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  border-radius: 0 0 32rpx 32rpx;
}

.avatar-ring {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  padding: 6rpx;
  background: rgba(255, 255, 255, 0.3);
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}

.avatar-img {
  width: 100% !important;
  height: 100% !important;
  border-radius: 50%;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 48rpx;
  height: 48rpx;
  background: var(--color-primary-dark);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.hero-nickname {
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.hero-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 卡片区 ===== */
.card-section {
  padding: 0 24rpx;
  margin-top: -32rpx;
  position: relative;
  z-index: 2;
}

.info-card {
  background: var(--bg-card);
  border-radius: var(--border-radius-lg);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--text-primary);
  position: relative;
  padding-left: 16rpx;
}

.card-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--color-primary);
  border-radius: 3rpx;
}

.char-counter {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

.char-counter.over {
  color: var(--color-error);
}

/* ===== 表单行 ===== */
.info-row {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  min-height: 80rpx;
}

.info-label {
  width: 140rpx;
  flex-shrink: 0;
  font-size: var(--font-size-md);
  color: var(--text-regular);
}

.info-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.info-input {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--text-primary);
  text-align: right;
}

.info-input.disabled {
  color: var(--text-secondary);
}

.info-text {
  flex: 1;
  font-size: var(--font-size-md);
  color: var(--text-primary);
  text-align: right;
}

.ph {
  color: var(--text-placeholder);
}

.cooldown-badge {
  display: flex;
  align-items: center;
  gap: 4rpx;
  background: #FFF1E6;
  color: var(--color-primary);
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: var(--border-radius-round);
  white-space: nowrap;
}

.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 0;
}

/* ===== 简介区 ===== */
.bio-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: var(--font-size-md);
  color: var(--text-primary);
  line-height: 1.7;
  padding: 16rpx;
  background: var(--bg-hover);
  border-radius: var(--border-radius-md);
  box-sizing: border-box;
}

/* ===== 底部按钮 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 10;
}
