.order-detail-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
}

.status-bar {
  display: flex;
  justify-content: center;
  padding: 32rpx 0 16rpx;
}

.detail-content {
  padding: 0 24rpx;
}

/* 核销码区域 */
.verify-code-section {
  margin: 24rpx 0;
  text-align: center;
}

.verify-code-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.verify-code-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #0052d9;
  letter-spacing: 8rpx;
}

.verify-code-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

.verify-code-expire {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 状态流转 */
.status-flow {
  margin: 24rpx 0;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.status-flow__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.status-flow__step {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.status-flow__arrow {
  margin: 0 8rpx;
  color: #999;
}

.status-flow__time {
  margin-left: 16rpx;
  color: #999;
}

.status-flow__remark {
  margin-left: 16rpx;
  color: #999;
  font-size: 22rpx;
}

/* 弹窗内输入框 */
.verify-input,
.cancel-input {
  width: 100%;
  height: 64rpx;
  padding: 0 16rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  font-size: 28rpx;
}

/* 底部固定按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 10;
}
