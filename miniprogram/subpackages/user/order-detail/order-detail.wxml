<view class="order-detail-page">
  <!-- 加载中 -->
  <t-loading wx:if="{{loading}}" theme="circular" size="40px" text="加载中..." />

  <!-- 加载错误 -->
  <view wx:elif="{{loadError}}" class="error-wrap">
    <text class="error-text">加载失败</text>
    <t-button size="small" bindtap="loadDetail">重试</t-button>
  </view>

  <view wx:elif="{{order}}" class="detail-content">
    <!-- 状态标签 -->
    <view class="status-bar">
      <t-tag
        theme="{{statusTheme}}"
        size="large"
      >
        {{ORDER_STATUS_MAP[order.status]}}
      </t-tag>
    </view>

    <!-- 订单信息 -->
    <t-cell-group bordered>
      <t-cell title="订单号" note="{{order.orderNo}}" />
      <t-cell title="服务标题" note="{{order.title}}" />
      <t-cell title="积分金额" note="{{order.pointAmount}} 积分" />
      <t-cell title="分类" note="{{order.skillTagName}}" />
      <t-cell title="服务时长" note="{{order.durationMinutes}} 分钟" />
      <t-cell title="创建时间" note="{{order.createTime}}" />
    </t-cell-group>

    <!-- 对方信息 -->
    <t-cell-group bordered title="{{order.myRole === 'buyer' ? '卖家' : '买家'}}">
      <t-cell title="{{order.myRole === 'buyer' ? order.sellerNickname : order.buyerNickname}}" note="{{order.myRole === 'buyer' ? '卖家' : '买家'}}" />
    </t-cell-group>

    <!-- 状态流转 -->
    <view wx:if="{{order.statusLogs && order.statusLogs.length}}" class="status-flow">
      <view class="status-flow__title">状态记录</view>
      <view wx:for="{{order.statusLogs}}" wx:key="createTime" class="status-flow__step">
        <text class="status-flow__from">{{ORDER_STATUS_MAP[item.fromStatus]}}</text>
        <text class="status-flow__arrow">→</text>
        <text class="status-flow__to">{{ORDER_STATUS_MAP[item.toStatus]}}</text>
        <text class="status-flow__time">{{item.createTime}}</text>
        <text wx:if="{{item.remark}}" class="status-flow__remark">{{item.remark}}</text>
      </view>
    </view>

    <!-- 核销码 -->
    <view wx:if="{{order.verifyCode}}" class="verify-code-section">
      <view class="verify-code-box" bindtap="onCopyVerifyCode">
        <text class="verify-code-text">{{order.verifyCode}}</text>
        <text class="verify-code-hint">点击复制核销码</text>
      </view>
      <text wx:if="{{order.verifyCodeExpire}}" class="verify-code-expire">有效期至 {{order.verifyCodeExpire}}</text>
    </view>

    <!-- 备注 -->
    <t-cell-group wx:if="{{order.remark}}" bordered title="备注">
      <t-cell title="{{order.remark}}" />
    </t-cell-group>
  </view>

  <!-- 底部操作按钮 -->
  <view wx:if="{{order}}" class="bottom-actions">
    <!-- 核销按钮（卖家 + 服务中） -->
    <t-button
      wx:if="{{order.myRole === 'seller' && order.status === 3}}"
      theme="primary"
      size="large"
      block
      loading="{{actionLoading}}"
      bindtap="onShowVerifyDialog"
    >
      核销服务
    </t-button>

    <!-- 确认完成按钮（买家 + 待确认） -->
    <t-button
      wx:if="{{order.myRole === 'buyer' && order.status === 4}}"
      theme="primary"
      size="large"
      block
      loading="{{actionLoading}}"
      bindtap="onConfirmComplete"
    >
      确认完成
    </t-button>

    <!-- 取消按钮（待支付 / 已支付） -->
    <t-button
      wx:if="{{order.status === 1 || order.status === 2}}"
      theme="light"
      size="large"
      block
      loading="{{actionLoading}}"
      bindtap="onShowCancelDialog"
    >
      取消订单
    </t-button>
  </view>

  <!-- 核销弹窗 -->
  <t-dialog
    visible="{{showVerifyDialog}}"
    title="输入核销码"
    content=""
    confirm-btn="确认核销"
    cancel-btn="取消"
    bind:confirm="onConfirmVerify"
    bind:cancel="onCloseVerifyDialog"
  >
    <input
      slot="content"
      class="verify-input"
      placeholder="请输入核销码"
      value="{{verifyCodeInput}}"
      bindinput="onVerifyCodeInput"
    />
  </t-dialog>

  <!-- 取消弹窗 -->
  <t-dialog
    visible="{{showCancelDialog}}"
    title="取消订单"
    content=""
    confirm-btn="确认取消"
    cancel-btn="再想想"
    bind:confirm="onConfirmCancel"
    bind:cancel="onCloseCancelDialog"
  >
    <input
      slot="content"
      class="cancel-input"
      placeholder="取消原因（可选）"
      value="{{cancelReason}}"
      bindinput="onCancelReasonInput"
    />
  </t-dialog>
</view>
