.page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* ===== 应用信息区域 ===== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 56rpx;
  background: #fff;
  margin-bottom: 16rpx;
}

.app-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #0052d9, #0066ff);
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 82, 217, 0.25);
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.app-version {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.app-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
}

/* ===== 版权信息 ===== */
.copyright {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0;
  font-size: 24rpx;
  color: #bbb;
  line-height: 1.8;
}
