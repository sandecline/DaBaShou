/* 发布需求表单样式 — 与技能表单共享大部分样式 */

.page {
  padding-bottom: calc(120rpx + var(--safe-area-bottom));
}

/* 分段卡片 */
.section {
  margin: 24rpx;
  padding: 32rpx;
  background: var(--color-white);
  border-radius: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  display: block;
}

/* 分类选择器 */
.picker-row {
  display: flex;
  gap: 24rpx;
}

.picker-item {
  flex: 1;
}

.picker-label {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
  margin-bottom: 12rpx;
  display: block;
}

.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.required {
  color: var(--color-danger);
}

.char-count {
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

.char-count.over-limit {
  color: var(--color-danger);
}

/* 提示文字 */
.form-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-placeholder);
}

/* Radio 选项列 */
.radio-column {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.radio-option {
  display: flex;
  align-items: center;
}

.option-desc {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 服务方式 */
.radio-row {
  display: flex;
  gap: 48rpx;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.upload-image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 0 12rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-page);
}

.add-text {
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-wrap {
  margin: 48rpx 24rpx;
}
