<!-- 需求详情 -->
<view class="page">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <t-loading text="正在加载..." />
  </view>

  <!-- 加载错误 -->
  <view wx:elif="{{loadError}}" class="error-wrap">
    <text class="error-text">加载失败</text>
    <t-button size="small" bindtap="loadDetail">重试</t-button>
  </view>

  <block wx:elif="{{demand}}">
    <!-- 需求图片 -->
    <view class="cover-wrap" wx:if="{{demand.images && demand.images.length > 0}}">
      <t-image
        src="{{demand.images[0]}}"
        mode="aspectFill"
        class="cover-image"
        data-index="{{0}}"
        bindtap="onPreviewImage"
      />
      <view wx:if="{{demand.images.length > 1}}" class="image-count">
        <t-icon name="image" size="24rpx" color="#fff" />
        <text>1/{{demand.images.length}}</text>
      </view>
    </view>

    <!-- 信息卡片 -->
    <view class="info-section card">
      <!-- 标题 + 悬赏 -->
      <view class="info-header">
        <text class="demand-title">{{demand.title}}</text>
        <view class="reward-tag">
          <t-icon name="gift" size="36rpx" color="#d54941" />
          <text class="reward-value">{{demand.pointReward}}</text>
          <text class="reward-unit">积分</text>
        </view>
      </view>

      <!-- 截止时间 + 状态 -->
      <view class="deadline-row">
        <view class="deadline-badge {{expired ? 'expired' : 'active'}}">
          <t-icon name="time" size="28rpx" />
          <block wx:if="{{expired}}">
            <text>已过期</text>
          </block>
          <block wx:else>
            <t-count-down time="{{deadlineCountdown}}" format="DD天HH时mm分ss秒" />
          </block>
        </view>
        <t-tag
          size="small"
          theme="{{statusTheme}}"
        >{{statusLabel}}</t-tag>
      </view>

      <!-- 发布者信息 -->
      <view class="user-row">
        <t-image
          src="{{demand.avatar}}"
          mode="aspectFill"
          class="user-avatar"
        />
        <view class="user-info">
          <text class="user-name">{{demand.nickname}}</text>
          <t-tag
            size="small"
            variant="light"
            theme="{{trustTheme}}"
          >{{trustLabel}} · {{demand.trustScore}}</t-tag>
        </view>
        <t-button size="small" variant="outline" bindtap="onChat">联系TA</t-button>
      </view>

      <!-- 分隔线 -->
      <view class="divider" />

      <!-- 标签行 -->
      <view class="tag-row">
        <t-tag theme="danger" variant="light" wx:if="{{demand.demandType === 1}}">求助悬赏</t-tag>
        <t-tag theme="primary" variant="light" wx:elif="{{demand.demandType === 2}}">技能置换</t-tag>
        <t-tag>{{demand.skillTagName}}</t-tag>
        <t-tag
          variant="outline"
          theme="{{locationTheme}}"
        >
          {{locationLabel}}
        </t-tag>
      </view>

      <!-- 分隔线 -->
      <view class="divider" />

      <!-- 描述 -->
      <view class="desc-section">
        <text class="section-title">需求描述</text>
        <text class="desc-content">{{demand.description}}</text>
      </view>

      <!-- 详细信息 -->
      <t-cell-group>
        <t-cell title="发布时间" note="{{demand.createTime}}" arrow="{{false}}" />
        <t-cell
          title="截止时间"
          note="{{demand.deadline}}"
          arrow="{{false}}"
          wx:if="{{!expired}}"
        />
      </t-cell-group>
    </view>
  </block>

  <!-- 底部接单栏 -->
  <view class="bottom-bar" wx:if="{{!loading}}">
    <t-button
      theme="primary"
      block
      disabled="{{expired}}"
      loading="{{accepting}}"
      bindtap="onAccept"
    >{{expired ? '已过期' : '接单帮助'}}</t-button>
  </view>
</view>
