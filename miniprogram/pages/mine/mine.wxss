/* 个人中心样式 */

.page-mine {
  min-height: 100vh;
  background-color: var(--bg-page);
}

/* ===== 顶部橙色 Header ===== */
.mine-header {
  background: linear-gradient(135deg, #FF6E14 0%, #FF8A4C 100%);
  padding: var(--spacing-xl) var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
  border-radius: 0 0 28rpx 28rpx;
}

/* ===== 用户信息卡片 ===== */
.profile-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
}

.profile-avatar {
  flex-shrink: 0;
}

.profile-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
  overflow: hidden;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.profile-nickname {
  font-size: var(--font-size-xl);
  font-weight: 600;
  color: #ffffff;
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-tag {
  flex-shrink: 0;
}

.profile-campus {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.85);
}

/* ===== 未登录卡片 ===== */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-md);
}

.login-tip {
  font-size: var(--font-size-md);
  color: rgba(255, 255, 255, 0.85);
}

.login-btn {
  width: 360rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: var(--font-size-md);
  font-weight: 500;
  color: var(--color-primary);
  background-color: #ffffff;
  border: none;
  border-radius: var(--border-radius-round);
}

.login-btn::after {
  border: none;
}

/* ===== 菜单 ===== */
t-cell-group {
  margin: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--border-radius-lg);
  overflow: hidden;
}

/* ===== 安全区 ===== */
.safe-bottom {
  height: calc(var(--safe-area-bottom) + var(--tabbar-height));
}
