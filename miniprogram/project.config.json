    "compileWorklet": false,
    "minifyWXSS": true,
    "minifyWXML": true,
    "localPlugins": false,
    "disableUseStrict": false,
    "useCompilerPlugins": ["typescript"],
    "condition": false,
    "swc": false,
    "disableSWC": true
  },
  "compileType": "miniprogram",
  "libVersion": "3.6.6",
  "appid": "wx88d4257e11c1e293",
  "projectname": "dabashou-miniprogram",
  "condition": {},
  "editorSetting": {
    "tabIndent": "insertSpaces",
