<view class="loading-skeleton loading-{{type}}">
  <!-- Card type: 1 image area + 3 text rows -->
  <block wx:if="{{type === 'card'}}">
    <view class="skeleton-card">
      <view class="skeleton-row skeleton-image-row">
        <t-skeleton rowCol="{{[1, 1, 1, {width: '30%'}]}}" loading />
      </view>
    </view>
  </block>

  <!-- List type: 3 repeated card-like rows -->
  <block wx:if="{{type === 'list'}}">
    <view class="skeleton-card" wx:for="{{[1, 2, 3]}}" wx:key="*this">
      <view class="skeleton-row">
        <t-skeleton rowCol="{{[{width: '40%'}, 1, {width: '60%'}]}}" loading />
      </view>
    </view>
  </block>

  <!-- Detail type: 1 large image area + 4 text rows -->
  <block wx:if="{{type === 'detail'}}">
    <view class="skeleton-detail">
      <view class="skeleton-image-large">
        <t-skeleton rowCol="{{[{width: '100%', height: '320rpx'}]}}" loading />
      </view>
      <view class="skeleton-text-block">
        <t-skeleton rowCol="{{[1, 1, {width: '70%'}, {width: '40%'}]}}" loading />
      </view>
    </view>
  </block>
</view>
