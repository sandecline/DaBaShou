.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

.empty-action {
  margin-top: 32rpx;
  padding: 12rpx 40rpx;
  border: 2rpx solid #ff6b35;
  border-radius: 40rpx;
}

.action-text {
  font-size: 28rpx;
  color: #ff6b35;
}
