.skill-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 24rpx;
  margin: 16rpx 24rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-left {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.skill-image {
  border-radius: 12rpx;
  overflow: hidden;
}

.card-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.skill-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.skill-tag {
  margin-top: 12rpx;
}

.skill-price {
  margin-top: 12rpx;
  display: flex;
  align-items: baseline;
}

.price-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-price);
}

.price-unit {
  font-size: 24rpx;
  color: var(--color-price);
  margin-left: 4rpx;
}

.skill-footer {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.user-name {
  font-size: 24rpx;
  color: #999;
}
